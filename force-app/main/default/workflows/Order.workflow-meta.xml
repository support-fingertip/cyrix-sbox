<?xml version="1.0" encoding="UTF-8"?>
<!--
    Workflow field updates and email alerts used by Order automations.
    Approval process:         approvalProcesses/Order.Order_Approval.approvalProcess-meta.xml
    Cancellation notifier:    flows/Order_Cancellation_Notifier.flow-meta.xml
-->
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Order_Cancelled_Owner_Notification</fullName>
        <description>Notifies the Order Owner that the Order has been cancelled.</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Order_Notifications/Order_Cancellation_Notification</template>
    </alerts>
    <fieldUpdates>
        <fullName>Order_Approved_Date_Time</fullName>
        <field>Quote_Approved_Date_Time__c</field>
        <formula>NOW()</formula>
        <name>Order Approved Date Time</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Order_Approved</fullName>
        <field>Approval_Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Order Approved</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Order_Rejected</fullName>
        <field>Approval_Status__c</field>
        <literalValue>Rejected</literalValue>
        <name>Order Rejected</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Order_Activated</fullName>
        <field>Status</field>
        <literalValue>Activated</literalValue>
        <name>Order Activated</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Order_Price_Status_Approved</fullName>
        <field>Price_Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Order Price Status Approved</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
</Workflow>

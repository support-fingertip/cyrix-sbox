<apex:page standardController="Quote" extensions="QuotationPDFController" renderAs="pdf" showHeader="false" sidebar="false" applyHtmlTag="false" applyBodyTag="false" standardStylesheets="false">
    <html>
        <head>
            <style type="text/css">
                /* Reserve top space for the letterhead logo + running quote header,
                and bottom space for the letterhead footer band. Content flows
                inside the remaining content box and auto-paginates.
                All paged-media dimensions in mm - Flying Saucer is strict about
                consistent absolute units in @page and fixed-positioned elements. */
                @page {
                size: A4;
                margin: 53mm 16mm 22mm 16mm;
                }

                body {
                font-family: 'Times New Roman', Times, serif;
                line-height: 1.4;
                margin: 0;
                padding: 0;
                font-size: 12.9px;
                }

                /* Each logical section starts on a fresh physical page.
                No fixed height, no overflow:hidden - let the engine paginate. */
                .page {
                position: relative;
                page-break-after: always;
                z-index: 2;
                }
                .page:last-child {
                page-break-after: auto;
                }

                /* position:fixed elements are repeated on EVERY page by Flying Saucer.
                Coordinates are relative to the content box, so negative offsets
                reach into the page margins. */
                .letterhead-bg {
                position: fixed;
                top: -53mm;
                left: -16mm;
                width: 210mm;
                height: 297mm;
                z-index: 0;
                }

                /* Running quote header - sits in the top margin, below the logo,
                above the content area, repeats on every page. */
                .page-header {
                position: fixed;
                top: -9mm;
                left: 0;
                right: 0;
                z-index: 2;
                font-size: 14px;
                }
                .header-inner {
                width: 100%;
                border-collapse: collapse;
                }
                .header-inner td {
                border: none;
                padding: 0;
                }

                /* Body content flows inside the @page content box.
                No absolute positioning - pagination is automatic. */
                .page-body {
                position: relative;
                z-index: 2;
                }
                
                .capitalize {
                text-transform: uppercase;
                }
                
                table.data-table {
                width: 100%;
                border-collapse: collapse;
                }
                table.data-table th,
                table.data-table td {
                font-family: 'Times New Roman', Times, serif;
                }
            </style>
        </head>
        <body>

            <!-- Rendered ONCE. position:fixed makes Flying Saucer repeat both
                 of these on every physical page of the PDF. -->
            <apex:image url="{!URLFOR($Resource.Letter_Head)}" styleClass="letterhead-bg" />

            <div class="page-header">
                <table class="header-inner">
                    <tr>
                        <td style="width: 80%; text-align: left;">
                            <span style="color: #000000;">{!quote.Name}</span>
                        </td>
                        <td style="width: 20%; text-align: center;">
                            <span style="color: #000000;">DATE:</span>
                            <apex:outputText value="{0,date,dd/MM/yyyy}">
                                <apex:param value="{!quote.Quote_Date__c}" />
                            </apex:outputText>
                        </td>
                    </tr>
                </table>
            </div>

            <!-- ====================================================================== -->
            <!-- PAGE 1: COVER LETTER                                                    -->
            <!-- ====================================================================== -->
            <div class="page">
                <div class="page-body">
                    
                    <div style="font-weight: 700; padding-bottom: 12px;">
                        <p>To,</p>
                        <div style="width: 40%;" class="capitalize">
                            <p>
                                <strong>{!quote.account.Name}</strong><br/>
                                {!quote.BillingCity}, {!quote.BillingState}<br/>
                                <apex:outputPanel rendered="{!quote.account.GST_Number__c != null}">
                                    <strong>GST:</strong> {!quote.account.GST_Number__c}<br/>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!quote.account.PAN_Number__c != null}">
                                    <strong>PAN:</strong> {!quote.account.PAN_Number__c}
                                </apex:outputPanel>
                            </p>
                        </div>
                        <p style="text-align: center; font-weight: bold; margin: 10px 0;">
                            SUBJECT: QUOTATION FOR <span class="capitalize">{!quote.Business_Vertical__c}</span>
                        </p>
                    </div>
                    
                    <div style="padding-bottom: 12px; line-height: 1.5; text-align: justify;">
                        <p><strong>Dear Sir/Madam,</strong></p>
                        <div>Greetings from Cyrix Healthcare Pvt Ltd!!!</div><br/>
                        <div>
                            We sincerely appreciate your continued trust in our products and services. As per your
                            requirement, we are pleased to submit our proposal for
                            <strong>{!quote.Business_Vertical__c}</strong> for your kind consideration.
                        </div>
                        
                        <apex:variable var="pIdx" value="{!1}" />
                        <apex:repeat value="{!lineItems}" var="pName">
                            <p style="font-weight: bold; margin: 3px 0;">
                                <apex:outputText value="{0, number, 0}">
                                    <apex:param value="{!pIdx}" />
                                </apex:outputText>. {!pName.Product2.Name}
                            </p>
                            <apex:variable var="pIdx" value="{!pIdx + 1}" />
                        </apex:repeat>
                        
                        <p>
                            At Cyrix Healthcare, we are committed to providing high-quality medical equipment and
                            reliable service support that meet your clinical and operational needs. We believe this
                            proposal will align well with your expectations and add value to your facility&#8217;s
                            healthcare delivery.
                        </p>
                        <p>
                            Please find the detailed quotation attached for your review. Should you require any
                            further clarification or technical discussion, we will be glad to assist at your
                            convenience.
                        </p>
                        <p>Thank you for the opportunity to serve your esteemed organization.</p>
                    </div>
                    
                    <div style="margin-top: 10px;">
                        <p>With Regards,<br/>For Cyrix Healthcare Pvt. Ltd</p>
                        <apex:image url="{!URLFOR($Resource.Stamp)}" style="height: 70px; width: 80px;" />
                        <div style="font-size: 10px;">Authorized Signatory</div><br/>
                        <div>
                            For queries contact:
                            <div style="text-align: left; font-weight: 700; padding-top: 5px;">
                                <span>{!quote.Owner.Name}</span><br/>
                                <apex:outputPanel rendered="{!quote.Owner_Designation__c != null}">
                                    <span>{!quote.Owner_Designation__c}</span><br/>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!quote.Owner_Phone__c != null}">
                                    <span>{!quote.Owner_Phone__c}</span>
                                </apex:outputPanel>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
            
            <!-- ====================================================================== -->
            <!-- PAGE 2: PRODUCT TABLE + STANDARD T&C                                    -->
            <!-- ====================================================================== -->
            <div class="page">
                <!-- table-->
                <div class="page-body">
                    <apex:outputPanel rendered="{!and (quote.Sub_Vertical__c!= 'Calibration',quote.Sub_Vertical__c== 'AMC',quote.Sub_Vertical__c== 'CMC')}">
                        <div style="text-align: center; font-weight: bold; margin: 6px 0 8px 0; text-decoration: underline; padding-bottom: 20px;">
                            QUOTATION FOR CYRIX <span class="capitalize">{!productName}<apex:outputPanel rendered="{!quote.Business_Vertical__c != null}"> &amp; {!quote.Business_Vertical__c}</apex:outputPanel></span>
                        </div>
                        
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width: 30px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>SLNo</strong></th>
                                    <th style="width: 60px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>ITEM CODE</strong></th>
                                    <th style="border: 1px solid #000; padding: 4px;"><strong>Description of Goods</strong></th>
                                    <th style="width: 40px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Unit</strong></th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Unit Price</strong></th>
                                    <th style="width: 30px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Qty</strong></th>
                                    <th style="width: 55px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Price</strong></th>
                                    <th style="width: 55px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Tax</strong></th>
                                    <th style="width: 55px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Total</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <apex:variable var="rowNum" value="{!1}" />
                                <apex:repeat value="{!lineItems}" var="item">
                                    <tr>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: center;">
                                            <apex:outputText value="{0, number, 0}"><apex:param value="{!rowNum}" /></apex:outputText>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{!IF(item.Product2.Item_Code__c != null, item.Product2.Item_Code__c, item.Product2.ProductCode)}" />
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px;">
                                            <strong>{!item.Product2.Name}</strong>
                                            <apex:outputPanel rendered="{!item.Product_Line_Description__c != null}">
                                                <br/><br/>({!item.Product_Line_Description__c})
                                            </apex:outputPanel>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: center;">
                                            <apex:outputText value="{!IF(item.Product2.QuantityUnitOfMeasure != null, item.Product2.QuantityUnitOfMeasure, 'Nos')}" />
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                                            <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!item.ListPrice}" /></apex:outputText>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: center;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!item.Quantity}" /></apex:outputText>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                                            <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!item.TotalPrice}" /></apex:outputText>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                                            <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!item.TotalPrice}" /></apex:outputText>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                                            <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!item.TotalPrice}" /></apex:outputText>
                                        </td>
                                    </tr>
                                    <apex:variable var="rowNum" value="{!rowNum + 1}" />
                                </apex:repeat>
                                
                                <tr>
                                    <td colspan="8" style="border: 1px solid #000; padding: 4px; text-align: center; font-weight: bold;">Grand Total</td>
                                    <td style="border: 1px solid #000; padding: 4px; text-align: right; font-weight: bold;">
                                        <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!quote.grandTotal}" /></apex:outputText>
                                    </td>
                                </tr>
                            </tbody>
                            
                        </table>
                        <p style="font-weight: bold;">{!grandTotalInWords}</p>
                        <apex:outputPanel rendered="{!quote.Notes__c != null}"><p style="font-weight: bold; color: #cc0000;">***Note: {quote.Notes__c}</p></apex:outputPanel>
                        <br/>
                    </apex:outputPanel>
                    
                    <apex:outputPanel rendered="{!quote.Sub_Vertical__c== 'Calibration'}">
                        <div style="text-align: center; font-weight: bold; margin: 6px 0 8px 0; text-decoration: underline; padding-bottom: 20px;">
                            PROJECT COSTING - <apex:outputPanel rendered="{!quote.Business_Vertical__c != null}"> <span class="capitalize"> {!quote.Business_Vertical__c}</span></apex:outputPanel>
                        </div>
                        
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width: 30px; border: 1px solid #000;text-align: center; padding: 4px;">SN</th>
                                    <th style="width: 100px; border: 1px solid #000;text-align: center; padding: 4px;">EQUIPMENT</th>
                                    <th style="width: 35px; border: 1px solid #000;text-align: center; padding: 4px;">QTY</th>
                                    <th style="border: 1px solid #000; padding: 4px;text-align: center;">PARAMETER</th>
                                    <th style="width: 45px; border: 1px solid #000;text-align: center; padding: 4px;">UNIT RATE</th>
                                    <th style="width: 45px; border: 1px solid #000; text-align: center;padding: 4px;">RATE</th>
                                    <th style="width: 45px; border: 1px solid #000;text-align: center; padding: 4px;">GST</th>
                                    <th style="width: 45px; border: 1px solid #000;text-align: center; padding: 4px;">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <apex:variable var="calIdx" value="{!1}" />
                                <apex:repeat value="{!lineItems}" var="calItem">
                                    <tr>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, 0}"><apex:param value="{!calIdx}" /></apex:outputText>
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; font-weight: bold;">{!calItem.Product2.Name}</td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px; font-weight: bold;">
                                            <apex:outputText value="{!IF(calItem.Product2.QuantityUnitOfMeasure != null, calItem.Product2.QuantityUnitOfMeasure, 'NOS')}" />
                                        </td>
                                        <td style="border: 1px solid #000; padding: 4px; font-weight: bold; text-decoration: underline;">
                                            <apex:outputText value="{!IF(calItem.Product_Line_Description__c != null, calItem.Product_Line_Description__c, 'AS PER THE EQUIPMENT TYPE')}" />
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!calItem.ListPrice}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: right; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!calItem.TotalPrice}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!calItem.ListPrice}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: right; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!calItem.TotalPrice}" /></apex:outputText>
                                        </td>
                                    </tr>
                                    <apex:variable var="calIdx" value="{!calIdx + 1}" />
                                </apex:repeat>
                                <tr>
                                    <td COLSPAN="7" style="border: 1px solid #000; padding: 4px; text-align: center; font-weight: bold;">GRAND TOTAL</td>
                                    <td style="border: 1px solid #000; padding: 4px; text-align: right; font-weight: bold;">
                                        <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!quote.grandTotal}" /></apex:outputText>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <p style="font-weight: bold;">{!grandTotalInWords}</p>
                        <apex:outputPanel rendered="{!quote.Notes__c != null}"><p style="font-weight: bold; color: #cc0000;">***Note: {quote.Notes__c}</p></apex:outputPanel>
                        <br/>
                    </apex:outputPanel>
                    <br/>
                    <apex:outputPanel rendered="{!quote.Sub_Vertical__c== 'AMC'}">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width: 35px; border: 1px solid #000; padding: 4px;">SI NO.</th>
                                    <th style="width: 150px; border: 1px solid #000; padding: 4px;">CONTRACT TYPE</th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px;">RATE</th>
                                    <th style="width: 40px; border: 1px solid #000; padding: 4px;">GST %</th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px;">GST RATE</th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px;">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="text-align: center; border: 1px solid #000; padding: 4px;">1.</td>
                                    <td style="border: 1px solid #000; padding: 4px; font-weight: bold;" colspan="5">
                                        ANNUAL MAINTENANCE CONTRACT (AMC)<br/>
                                        <u>(Annexure A List of Equipment)</u>
                                    </td>
                                </tr>
                                <apex:repeat value="{!lineItems}" var="amcItem">
                                    <tr>
                                        <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                                        <td style="border: 1px solid #000; padding: 4px; font-weight: bold;">{!amcItem.Product2.Name}</td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!amcItem.TotalPrice}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{!IF(amcItem.Product2.Tax__c != null, TEXT(amcItem.Product2.Tax__c), '18')}"/>%
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!IF(amcItem.Product2.Tax__c != null, amcItem.TotalPrice * amcItem.Product2.Tax__c / 100, amcItem.TotalPrice * 0.18)}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!IF(amcItem.Product2.Tax__c != null, amcItem.TotalPrice + (amcItem.TotalPrice * amcItem.Product2.Tax__c / 100), amcItem.TotalPrice * 1.18)}" /></apex:outputText>
                                        </td>
                                    </tr>
                                </apex:repeat>
                                <tr>
                                    <td colspan="6" style="text-align: center; border: 1px solid #000; padding: 4px;">
                                        <strong>Contract Period: - 01/01/2026 to 31/12/2026</strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </apex:outputPanel>
                    <apex:outputPanel rendered="{!quote.Sub_Vertical__c== 'CMC'}">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width: 35px; border: 1px solid #000; padding: 4px;">SI NO.</th>
                                    <th style="width: 150px; border: 1px solid #000; padding: 4px;">CONTRACT TYPE</th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px;">RATE</th>
                                    <th style="width: 40px; border: 1px solid #000; padding: 4px;">GST %</th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px;">GST RATE</th>
                                    <th style="width: 50px; border: 1px solid #000; padding: 4px;">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="text-align: center; border: 1px solid #000; padding: 4px;">1.</td>
                                    <td style="border: 1px solid #000; padding: 4px; font-weight: bold;" colspan="5">
                                        ANNUAL MAINTENANCE CONTRACT (AMC)<br/>
                                        <u>(Annexure A List of Equipment)</u>
                                    </td>
                                </tr>
                                <apex:repeat value="{!lineItems}" var="amcItem">
                                    <tr>
                                        <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                                        <td style="border: 1px solid #000; padding: 4px; font-weight: bold;">{!amcItem.Product2.Name}</td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!amcItem.TotalPrice}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{!IF(amcItem.Product2.Tax__c != null, TEXT(amcItem.Product2.Tax__c), '18')}"/>%
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!IF(amcItem.Product2.Tax__c != null, amcItem.TotalPrice * amcItem.Product2.Tax__c / 100, amcItem.TotalPrice * 0.18)}" /></apex:outputText>
                                        </td>
                                        <td style="text-align: center; border: 1px solid #000; padding: 4px;">
                                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!IF(amcItem.Product2.Tax__c != null, amcItem.TotalPrice + (amcItem.TotalPrice * amcItem.Product2.Tax__c / 100), amcItem.TotalPrice * 1.18)}" /></apex:outputText>
                                        </td>
                                    </tr>
                                </apex:repeat>
                                <tr>
                                    <td colspan="6" style="text-align: center; border: 1px solid #000; padding: 4px;">
                                        <strong>Contract Period: - 01/01/2026 to 31/12/2026</strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </apex:outputPanel>
                    
                    
                    <apex:outputPanel rendered="{!quote.Sub_Vertical__c== 'Calibration'}">
                        <div style="text-align: center; font-weight: bold; text-decoration: underline; margin: 22px 0px 8px 0;">
                            STANDARD TERMS AND CONDITIONS:
                        </div>
                        
                        <div style="margin: 10px 0 3px 0;">
                            <span style="font-weight: bold; padding-bottom: 12px;">Validity</span><br/>
                            This quotation is valid for <strong>{!quote.Quote_Valid_Till_in_days__c}</strong> from the date of issue and is subject to reconfirmation thereafter.
                        </div>
                        
                        <div style="margin: 10px 0 10px 0;">
                            <span style="font-weight: bold;"> Price</span><br/>
                            <div style="text-align:justify">The quoted price includes applicable levies such as GST, import duties (if any), freight, packing, forwarding, transportation, insurance, <strong><u>cap</u></strong> at the installation site. Any additional statutory levies imposed by Government authorities shall be borne by the purchaser.</div>
                        </div>
                        
                        <div style="margin: 10px 0 10px 0;">
                            <div style="font-weight: bold; padding-bottom: 4px;"> PAYMENT TERMS &amp; CONDITIONS:</div>
                            <apex:outputPanel rendered="{!paymentTerms.size > 0}">
                                <apex:repeat value="{!paymentTerms}" var="pt">
                                    {!pt.Percentage__c}% &nbsp; {!pt.Payment_Term__c}<br/>
                                </apex:repeat>
                            </apex:outputPanel>
                        </div>
                    </apex:outputPanel>
                    
                    
                    <apex:outputPanel rendered="{!quote.Sub_Vertical__c!= 'CMC'}">
                        <div style="margin: 10px 0 10px 0;">
                            <div style="font-weight: bold; padding-bottom: 4px;">DELIVERY</div>
                            <div>Delivery will be scheduled within <strong>{!quote.Delivery__c}</strong> from receipt of confirmed Purchase Order along with advance payment.</div>
                        </div>
                        
                        <div style="margin: 10px 0 10px 0;">
                            <div style="font-weight: bold; padding-bottom: 4px;"> Installation &amp; Approvals</div>
                            <div style="text-align:justify; line-height: 1.4;">Installation will be carried out at the approved site without additional charges, subject to site readiness confirmation from the customer.</div>
                            <div style="text-align:justify; line-height: 1.5;">
                                All civil, electrical, air conditioning, earthing, and related pre-installation requirements are the responsibility of the purchaser.
                                Statutory approvals such as PC-PNDT and AERB (where applicable) must be obtained by the customer prior to installation.</div>
                        </div>
                    </apex:outputPanel>
                </div>
                <!-- table end-->
            </div>
            
            <!-- ====================================================================== -->
            <!-- PAGE 3: WARRANTY, BANK, ACCEPTANCE, CANCELLATION, SIGNATORY             -->
            <!-- ====================================================================== -->
            <div class="page">
                
                <div class="page-body">
                    <apex:outputPanel rendered="{!quote.Sub_Vertical__c!= 'Calibration'}">
                        <div style="margin: 10px 0 10px 0;">
                            <div style="font-weight: bold; padding-bottom: 4px;"> Warranty</div>
                            <div style=" line-height: 1.4;">

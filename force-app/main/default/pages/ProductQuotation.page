<apex:page standardController="Quote"
           extensions="QuotationPDFController"
           renderAs="pdf"
           showHeader="false"
           sidebar="false"
           applyHtmlTag="false"
           applyBodyTag="false"
           standardStylesheets="false">
<html>
<head>
<style type="text/css">
    @page {
        size: A4;
        margin: 8mm 15mm 20mm 15mm;

        @bottom-center {
            content: element(footer);
        }
    }
    body {
        font-family: 'Times New Roman', Times, serif;
        font-size: 10pt;
        color: #000000;
        line-height: 1.5;
    }

    /* ---------- FOOTER ---------- */
    .page-footer {
        position: running(footer);
        text-align: center;
        font-size: 7pt;
        color: #ffffff;
        font-weight: bold;
        background-color: #8b0000;
        border-top: 3px solid #cc0000;
        border-bottom: 3px solid #cc0000;
        padding: 5px 0;
    }

    /* ---------- COMPANY HEADER ---------- */
    .company-header {
        text-align: left;
        margin-bottom: 15px;
    }
    .company-logo {
        max-height: 50px;
    }
    .company-name {
        font-size: 14pt;
        font-weight: bold;
        color: #003366;
        margin: 0;
        letter-spacing: 2px;
    }
    .company-sub {
        font-size: 9pt;
        font-weight: bold;
        color: #003366;
        margin: 0;
    }
    .company-tagline {
        font-size: 7pt;
        color: #666666;
        font-style: italic;
        margin: 2px 0 8px 0;
    }

    /* ---------- QUOTE REF LINE ---------- */
    .ref-line {
        width: 100%;
        margin-top: 0px;
        margin-bottom: 15px;
        font-size: 9pt;
        color: #cc0000;
        font-weight: bold;
    }

    /* ---------- TO SECTION ---------- */
    .to-section {
        font-size: 9pt;
        margin-bottom: 15px;
    }

    /* ---------- SUBJECT ---------- */
    .subject {
        text-align: center;
        font-size: 9pt;
        font-weight: bold;
        color: #000000;
        margin: 10px 0 15px 0;
    }

    /* ---------- LETTER BODY ---------- */
    .letter-body {
        font-size: 9pt;
        text-align: justify;
        line-height: 1.5;
    }
    .letter-body p {
        margin: 10px 0;
    }
    .product-list {
        margin: 3px 0 3px 0;
        font-weight: bold;
        color: #000000;
    }

    /* ---------- SIGNATURE SECTION ---------- */
    .sign-section {
        margin-top: 30px;
    }
    .sign-line {
        border-bottom: 1px solid #333333;
        width: 200px;
        height: 40px;
    }

    /* ---------- PAGE BREAK ---------- */
    .page-break {
        page-break-before: always;
    }

    /* ---------- PRICING TABLE (for later pages) ---------- */
    .pricing-table {
        width: 100%;
        border-collapse: collapse;
        margin: 15px 0;
    }
    .pricing-table th {
        background-color: #ffffff;
        color: #000000;
        font-size: 9pt;
        padding: 6px 4px;
        border: 1px solid #000000;
        text-align: center;
        font-weight: bold;
    }
    .pricing-table td {
        border: 1px solid #000000;
        padding: 5px 4px;
        font-size: 9pt;
        vertical-align: top;
    }
    .pricing-table .num-col {
        text-align: center;
        width: 35px;
    }
    .pricing-table .code-col {
        width: 80px;
    }
    .pricing-table .desc-col {
        width: auto;
    }
    .pricing-table .unit-col {
        text-align: center;
        width: 45px;
    }
    .pricing-table .price-col {
        text-align: right;
        width: 85px;
    }
    .pricing-table .qty-col {
        text-align: center;
        width: 40px;
    }
    .total-row td {
        font-weight: bold;
        background-color: #f9f9f9;
    }
    .grand-total-row td {
        font-weight: bold;
        background-color: #e8e8e8;
        font-size: 10pt;
    }
    .total-words {
        margin: 10px 0;
        font-weight: bold;
        font-style: italic;
        font-size: 10pt;
    }

    /* ---------- TERMS AND CONDITIONS ---------- */
    .section-title {
        font-size: 11pt;
        font-weight: bold;
        color: #003366;
        margin: 20px 0 8px 0;
        border-bottom: 1px solid #003366;
        padding-bottom: 3px;
    }
    .tc-list {
        margin: 0;
        padding-left: 20px;
    }
    .tc-list li {
        margin-bottom: 5px;
        font-size: 9pt;
        text-align: justify;
    }

    /* ---------- BANK TABLE ---------- */
    .bank-table {
        border-collapse: collapse;
        width: 50%;
        margin: 10px 0;
    }
    .bank-table td {
        border: 1px solid #cccccc;
        padding: 4px 8px;
        font-size: 9pt;
    }
    .bank-table .bank-label {
        font-weight: bold;
        background-color: #f0f0f0;
        width: 40%;
    }

    /* ---------- ACCEPTANCE ---------- */
    .acceptance-box {
        border: 1px solid #cccccc;
        padding: 15px;
        margin: 15px 0;
    }
</style>
</head>
<body>

    <!-- RUNNING FOOTER (appears on every page) -->
    <div class="page-footer">
        {!companyCin}
    </div>

    <!-- ====================================================================== -->
    <!-- PAGE 1: COVER LETTER                                                   -->
    <!-- ====================================================================== -->

    <!-- COMPANY HEADER WITH LOGO -->
    <div class="company-header">
        <apex:image url="{!URLFOR($Resource.Cyrix_Logo)}" styleClass="company-logo" />
    </div>

    <!-- QUOTE REFERENCE LINE -->
    <table class="ref-line">
        <tr>
            <td style="text-align: left; width: 70%;">
                <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
            </td>
            <td style="text-align: right; width: 30%;">
                <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
            </td>
        </tr>
    </table>

    <!-- TO SECTION -->
    <div class="to-section">
        <p>To,</p>
        <p>
            <strong>{!account.Name}</strong><br/>
            <apex:outputPanel rendered="{!quote.Billing_Address__c != null}">
                {!quote.Billing_Address__c}<br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!account.BillingStreet != null && quote.Billing_Address__c == null}">
                {!account.BillingStreet}<br/>
                {!account.BillingCity}<apex:outputPanel rendered="{!account.BillingState != null}">, {!account.BillingState}</apex:outputPanel>
                <apex:outputPanel rendered="{!account.BillingPostalCode != null}"> - {!account.BillingPostalCode}</apex:outputPanel><br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!account.BillingCity != null && quote.Billing_Address__c == null}">
                {!account.BillingCity}<br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!account.GST_Number__c != null}">
                **<strong>GST:</strong> {!account.GST_Number__c}<br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!account.PAN_Number__c != null}">
                <strong>PAN:</strong> {!account.PAN_Number__c}
            </apex:outputPanel>
        </p>
    </div>

    <!-- SUBJECT -->
    <div class="subject">
        SUBJECT: QUOTATION FOR &ldquo;{!quote.Vertical__c}&rdquo;
    </div>

    <!-- LETTER BODY -->
    <div class="letter-body">
        <p><strong>Dear Sir/Madam,</strong></p>

        <p>Greetings from Cyrix Healthcare Pvt Ltd!!!</p>

        <p>We sincerely appreciate your continued trust in our products and services. As per your requirement, we are pleased
           to submit our proposal for <strong>{!quote.Vertical__c}</strong> for your kind consideration.</p>

        <!-- Numbered Product List -->
        <apex:variable var="pIdx" value="{!1}" />
        <apex:repeat value="{!productNamesNumbered}" var="pName">
            <p class="product-list">
                <apex:outputText value="{0, number, 0}">
                    <apex:param value="{!pIdx}" />
                </apex:outputText>.&lt;{!pName}&gt;
            </p>
            <apex:variable var="pIdx" value="{!pIdx + 1}" />
        </apex:repeat>

        <p>At Cyrix Healthcare, we are committed to providing high-quality medical equipment and reliable service support
           that meet your clinical and operational needs. We believe this proposal will align well with your expectations and
           add value to your facility&#8217;s healthcare delivery.</p>

        <p>Please find the detailed quotation attached for your review. Should you require any further clarification or
           technical discussion, we will be glad to assist at your convenience.</p>

        <p>Thank you for the opportunity to serve your esteemed organization.</p>
    </div>

    <!-- SIGNATURE SECTION -->
    <div class="sign-section">
        <p>With Regards,<br/>
           For Cyrix Healthcare Pvt. Ltd</p>

        <apex:image url="{!URLFOR($Resource.Stamp)}" style="max-height: 80px;" />

        <p style="margin-left: 30px; color: #0000cc;"><strong>Authorized Signatory</strong></p>

        <p>For queries contact:<br/>
            <apex:outputPanel rendered="{!salesEngineerName != null}">
                <span style="margin-left: 10px;">{!salesEngineerName}</span><br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!salesEngineerTitle != null}">
                <span style="margin-left: 10px;">{!salesEngineerTitle}</span><br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!salesEngineerPhone != null}">
                <span style="margin-left: 10px;">{!salesEngineerPhone}</span>
            </apex:outputPanel>
        </p>
    </div>

    <!-- ====================================================================== -->
    <!-- PAGE 2: PRODUCT TABLE + TERMS AND CONDITIONS                          -->
    <!-- ====================================================================== -->
    <div class="page-break"></div>

    <!-- COMPANY HEADER (repeated on page 2) -->
    <div class="company-header">
        <apex:image url="{!URLFOR($Resource.Cyrix_Logo)}" styleClass="company-logo" />
    </div>

    <!-- QUOTE REF LINE (repeated) -->
    <table class="ref-line">
        <tr>
            <td style="text-align: left; width: 70%;">
                <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
            </td>
            <td style="text-align: right; width: 30%;">
                <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
            </td>
        </tr>
    </table>

    <!-- QUOTATION TITLE -->
    <div style="text-align: center; font-size: 8pt; font-weight: bold; margin-top: 10px; margin-bottom: 10px; text-decoration: underline;">
        QUOTATION FOR CYRIX {!productNamesList}<apex:outputPanel rendered="{!quote.Vertical__c != null}"> &amp; {!quote.Vertical__c}</apex:outputPanel>
    </div>

    <!-- PRICING TABLE -->
    <table class="pricing-table">
        <thead>
            <tr>
                <th class="num-col"><strong>SLN<br/>o</strong></th>
                <th class="code-col"><strong>ITEM<br/>CODE</strong></th>
                <th class="desc-col"><strong>Description of Goods</strong></th>
                <th class="unit-col"><strong>Unit</strong></th>
                <th class="price-col"><strong>Unit<br/>Price</strong></th>
                <th class="qty-col"><strong>Qty</strong></th>
                <th class="price-col"><strong>Price</strong></th>
            </tr>
        </thead>
        <tbody>
            <apex:variable var="rowNum" value="{!1}" />
            <apex:repeat value="{!lineItems}" var="item">
                <tr>
                    <td class="num-col">
                        <apex:outputText value="{0, number, 0}">
                            <apex:param value="{!rowNum}" />
                        </apex:outputText>
                    </td>
                    <td class="code-col">
                        <apex:outputText value="{!IF(item.Product2.Item_Code__c != null, item.Product2.Item_Code__c, item.Product2.ProductCode)}" />
                    </td>
                    <td class="desc-col">
                        <strong>{!item.Product2.Name}</strong>
                        <apex:outputPanel rendered="{!item.Product_Line_Description__c != null}">
                            <br/><br/>({!item.Product_Line_Description__c})
                        </apex:outputPanel>
                    </td>
                    <td class="unit-col">
                        <apex:outputText value="{!IF(item.Product2.QuantityUnitOfMeasure != null, item.Product2.QuantityUnitOfMeasure, 'Nos')}" />
                    </td>
                    <td class="price-col">
                        <apex:outputText value="{0, number, ###,##0.00}">
                            <apex:param value="{!item.UnitPrice}" />
                        </apex:outputText>
                    </td>
                    <td class="qty-col">
                        <apex:outputText value="{0, number, ###,##0}">
                            <apex:param value="{!item.Quantity}" />
                        </apex:outputText>
                    </td>
                    <td class="price-col">
                        <apex:outputText value="{0, number, ###,##0.00}">
                            <apex:param value="{!item.TotalPrice}" />
                        </apex:outputText>
                    </td>
                </tr>
                <apex:variable var="rowNum" value="{!rowNum + 1}" />
            </apex:repeat>

            <!-- Empty rows -->
            <tr>
                <td class="num-col">&nbsp;</td>
                <td class="code-col">&nbsp;</td>
                <td class="desc-col">&nbsp;</td>
                <td class="unit-col">&nbsp;</td>
                <td class="price-col">&nbsp;</td>
                <td class="qty-col">&nbsp;</td>
                <td class="price-col">&nbsp;</td>
            </tr>

            <!-- TOTAL ROW - last column only -->
            <tr>
                <td style="border: none;" colspan="5">&nbsp;</td>
                <td style="border: 1px solid #000000; text-align: right; padding-right: 5px; font-weight: bold;">Total</td>
                <td style="border: 1px solid #000000; text-align: right; padding-right: 5px;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!subtotal}" />
                    </apex:outputText>
                </td>
            </tr>

            <!-- GST ROW - last column only -->
            <tr>
                <td style="border: none;" colspan="5">&nbsp;</td>
                <td style="border: 1px solid #000000; text-align: right; padding-right: 5px;">
                    {!gstDisplayRate}
                </td>
                <td style="border: 1px solid #000000; text-align: right; padding-right: 5px;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!taxAmount}" />
                    </apex:outputText>
                </td>
            </tr>

            <!-- GRAND TOTAL ROW - last column only -->
            <tr>
                <td style="border: none;" colspan="5">&nbsp;</td>
                <td style="border: 1px solid #000000; text-align: right; padding-right: 5px; font-weight: bold;">Grand Total</td>
                <td style="border: 1px solid #000000; text-align: right; padding-right: 5px; font-weight: bold;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!grandTotal}" />
                    </apex:outputText>
                </td>
            </tr>
        </tbody>
    </table>

    <!-- GRAND TOTAL IN WORDS -->
    <p style="font-weight: bold; font-size: 9pt; margin: 10px 0 0 0;">
        &lt;{!grandTotalInWords}&gt;
    </p>
    <!-- NOTE -->
    <p style="font-size: 8pt; font-weight: bold; color: #cc0000; margin: 2px 0 20px 15px;">
        ***Note: If required
    </p>

    <!-- ====================================================================== -->
    <!-- STANDARD TERMS AND CONDITIONS (same page, below table)                -->
    <!-- ====================================================================== -->

    <div style="text-align: center; font-size: 10pt; font-weight: bold; text-decoration: underline; margin: 15px 0 12px 0;">
        STANDARD TERMS AND CONDITIONS:
    </div>

    <!-- Validity -->
    <p style="font-size: 9pt; font-weight: bold; margin: 12px 0 3px 0;">Validity</p>
    <p style="font-size: 9pt; margin: 0 0 10px 0;">
        This quotation is valid for <strong>{!validityDays}</strong> from the date of issue and is subject to reconfirmation thereafter.
    </p>

    <!-- Price -->
    <p style="font-size: 9pt; font-weight: bold; margin: 12px 0 3px 0;">Price</p>
    <p style="font-size: 9pt; margin: 0 0 10px 0;">
        The quoted price includes applicable levies such as GST, import duties (if any), freight, packing, forwarding,
        transportation, insurance, <strong><u>{!installationScope}</u></strong> at the installation site.
        Any additional statutory levies imposed by Government authorities shall be borne by the purchaser.
    </p>

    <!-- Payment Terms -->
    <p style="font-size: 9pt; font-weight: bold; margin: 12px 0 3px 0;">PAYMENT TERMS &amp; CONDITIONS:</p>
    <p style="font-size: 9pt; margin: 0 0 10px 0;">
        <apex:outputPanel rendered="{!paymentTerms.size > 0}">
            <apex:repeat value="{!paymentTerms}" var="pt">
                <strong>{!pt.Percentage__c}%</strong> {!pt.Name}<br/>
            </apex:repeat>
        </apex:outputPanel>
        <apex:outputPanel rendered="{!paymentTerms.size == 0}">
            <strong>{!advancePercent}</strong> Advance payment with Purchase Order<br/>
            <strong>{!shippingPercent}</strong> payment on confirmation of shipping<br/>
            <strong>{!deliveryPercent}</strong> payment on delivery to site<br/>
            <strong>{!installationPercent}</strong> payment after installation and handover
        </apex:outputPanel>
    </p>

    <!-- Delivery -->
    <p style="font-size: 9pt; font-weight: bold; margin: 12px 0 3px 0;">DELIVERY</p>
    <p style="font-size: 9pt; margin: 0 0 10px 0;">
        Delivery will be scheduled within <strong>{!deliveryWeeks}</strong> from receipt of confirmed Purchase Order along with advance payment.
    </p>

    <!-- Installation and Approvals -->
    <p style="font-size: 9pt; font-weight: bold; margin: 12px 0 3px 0;">Installation &amp; Approvals</p>
    <p style="font-size: 9pt; margin: 0 0 10px 0;">
        Installation will be carried out at the approved site without additional charges, subject to site readiness
        confirmation from the customer.
        All civil, electrical, air conditioning, earthing, and related pre-installation requirements are the responsibility of
        the purchaser.
        Statutory approvals such as PC-PNDT and AERB (where applicable) must be obtained by the customer prior to
        installation.
    </p>

    <!-- ====================================================================== -->
    <!-- PAGE 3: WARRANTY, BANK, ACCEPTANCE, CANCELLATION, SIGNATORY           -->
    <!-- ====================================================================== -->
    <div class="page-break"></div>

    <!-- COMPANY HEADER -->
    <div class="company-header">
        <apex:image url="{!URLFOR($Resource.Cyrix_Logo)}" styleClass="company-logo" />
    </div>

    <!-- QUOTE REF LINE -->
    <table class="ref-line">
        <tr>
            <td style="text-align: left; width: 70%;">
                <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
            </td>
            <td style="text-align: right; width: 30%;">
                <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
            </td>
        </tr>
    </table>

    <!-- WARRANTY -->
    <p style="font-size: 10pt; font-weight: bold; text-decoration: underline; margin: 10px 0 5px 0;">Warranty</p>
    <p style="font-size: 9pt; margin: 0 0 10px 10px;">
        12-month standard warranty <apex:outputPanel rendered="{!warrantyExtra != ''}"><strong><u>{!warrantyExtra}</u></strong></apex:outputPanel> from the date of installation covers manufacturing defects only.
        Repair or replacement of defective components during this period will be at the Company&#8217;s discretion.
        Warranty excludes damages arising from power fluctuations, environmental conditions, mishandling, natural
        calamities, pest-related issues, or third-party interference.
    </p>

    <!-- SITE RESPONSIBILITIES -->
    <p style="font-size: 10pt; font-weight: bold; margin: 12px 0 5px 15px;">Site Responsibilities</p>
    <p style="font-size: 9pt; margin: 0 0 10px 15px;">
        The customer shall maintain recommended environmental and electrical conditions. Any damage caused due to
        non-compliance will not be covered under warranty
    </p>

    <!-- BANK DETAILS -->
    <p style="font-size: 10pt; font-weight: bold; margin: 12px 0 5px 15px;">BANK DETAILS:</p>
    <p style="font-size: 9pt; margin: 0 0 10px 15px;">
        A/C Number: {!bankAccountNumber}<br/>
        Bank Name: {!bankName}<br/>
        Branch Code: {!bankBranch}<br/>
        IFSC: {!bankIfsc}
    </p>

    <!-- ACCEPTANCE OF QUOTATION -->
    <p style="font-size: 10pt; font-weight: bold; margin: 12px 0 5px 15px;">ACCEPTANCE OF QUOTATION:</p>
    <p style="font-size: 9pt; margin: 0 0 10px 15px;">
        The quotation shall be considered accepted upon issuance of a formal Purchase Order or written confirmation by the
        CLIENT. Acceptance of the quotation shall constitute agreement to all terms and conditions mentioned herein.
    </p>

    <!-- CANCELLATION/REFUND NORMS -->
    <p style="font-size: 10pt; font-weight: bold; margin: 12px 0 5px 15px;">CANCELLATION/REFUND NORMS:</p>
    <p style="font-size: 9pt; margin: 0 0 10px 15px;">
        Cancellation after issuance of Purchase Order will attract a <strong>10% charge</strong> on the total order value.
        Orders cannot be cancelled once the equipment is shipped.
    </p>

    <!-- FORCE MAJEURE -->
    <p style="font-size: 10pt; font-weight: bold; margin: 12px 0 5px 15px;">FORCE MAJEURE:</p>
    <p style="font-size: 9pt; margin: 0 0 10px 15px;">
        The Company shall not be liable for delays or non-performance due to circumstances beyond reasonable control.
        Delivery timelines will be extended accordingly.
    </p>

    <!-- JURISDICTION -->
    <p style="font-size: 10pt; font-weight: bold; margin: 12px 0 5px 15px;">JURISDICTION:</p>
    <p style="font-size: 9pt; margin: 0 0 10px 15px;">
        All disputes shall be subject to the jurisdiction of the Company&#8217;s registered office location.
    </p>

    <!-- CLOSING -->
    <p style="font-size: 9pt; margin-top: 20px;">
        Thanking you and always assuring you of our best services.
    </p>

    <p style="font-size: 10pt; font-weight: bold; margin-top: 12px;">
        For CYRIX HEALTHCARE PVT.LTD
    </p>

    <!-- STAMP/SEAL -->
    <div style="margin-top: 8px;">
        <apex:image url="{!URLFOR($Resource.Stamp)}" style="max-height: 70px;" />
    </div>

    <!-- AUTHORIZED SIGNATORY -->
    <p style="font-size: 9pt; font-weight: bold; color: #0000cc; margin-top: 3px;">
        Authorized Signatory
    </p>

    <!-- ====================================================================== -->
    <!-- PAGE 4: GENERAL/CALIBRATION OVERVIEW + CALIBRATION TABLE              -->
    <!-- ====================================================================== -->
    <div class="page-break"></div>

    <!-- COMPANY HEADER -->
    <div class="company-header">
        <apex:image url="{!URLFOR($Resource.Cyrix_Logo)}" styleClass="company-logo" />
    </div>

    <!-- QUOTE REF LINE -->
    <table class="ref-line">
        <tr>
            <td style="text-align: left; width: 70%;">
                <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
            </td>
            <td style="text-align: right; width: 30%;">
                <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
            </td>
        </tr>
    </table>

    <!-- HORIZONTAL LINE -->
    <hr style="border: none; border-top: 1px dashed #000000; margin: 15px 0;"/>

    <!-- IN GENERAL QUOTATIONS AND CONSUMABLES -->
    <p style="font-size: 10pt; font-weight: bold; font-style: italic; text-decoration: underline; margin: 15px 0 12px 0;">
        IN GENERAL QUOTATIONS AND CONSUMABLES
    </p>

    <p style="font-size: 9pt; font-weight: bold; text-decoration: underline; margin: 12px 0 10px 0;">

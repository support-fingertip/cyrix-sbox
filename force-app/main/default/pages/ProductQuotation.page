<apex:page standardController="Quote"
           extensions="QuotationPDFController"
           renderAs="pdf"
           showHeader="false"
           sidebar="false"
           applyHtmlTag="false"
           applyBodyTag="false"
           standardStylesheets="false">
<html>
<head>
<style type="text/css">
    @page {
        size: A4;
        margin: 0;
    }
    body {
        font-family: 'Times New Roman', Times, serif;
        font-size: 9pt;
        color: #000000;
        line-height: 1.5;
        margin: 0;
        padding: 0;
    }

    /* ---------- LETTERHEAD BACKGROUND ---------- */
    .page-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
    }
    .page-bg img {
        width: 100%;
        height: 100%;
    }

    /* ---------- CONTENT AREA ---------- */
    .content {
        padding: 45mm 18mm 22mm 18mm;
    }

    /* ---------- PAGE BREAK ---------- */
    .page-break {
        page-break-before: always;
    }
</style>
</head>
<body>

    <!-- LETTERHEAD BACKGROUND (fixed on every page) -->
    <div class="page-bg">
        <apex:image url="{!URLFOR($Resource.Letter_Head)}" style="width: 100%; height: 100%;" />
    </div>

    <!-- ====================================================================== -->
    <!-- PAGE 1: COVER LETTER                                                   -->
    <!-- ====================================================================== -->
    <div class="content">

        <!-- QUOTE REFERENCE LINE -->
        <table style="width: 100%; margin-bottom: 10px; font-size: 9pt; color: #cc0000; font-weight: bold;">
            <tr>
                <td style="text-align: left; width: 70%;">
                    <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
                </td>
                <td style="text-align: right; width: 30%;">
                    <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
                </td>
            </tr>
        </table>

        <!-- TO SECTION -->
        <p>To,</p>
        <p>
            <strong>{!account.Name}</strong><br/>
            <apex:outputPanel rendered="{!quote.Billing_Address__c != null}">
                {!quote.Billing_Address__c}<br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!account.GST_Number__c != null}">
                <strong>GST:</strong> {!account.GST_Number__c}<br/>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!account.PAN_Number__c != null}">
                <strong>PAN:</strong> {!account.PAN_Number__c}
            </apex:outputPanel>
        </p>

        <!-- SUBJECT -->
        <p style="text-align: center; font-weight: bold; margin: 10px 0;">
            SUBJECT: QUOTATION FOR &ldquo;{!quote.Vertical__c}&rdquo;
        </p>

        <!-- LETTER BODY -->
        <p><strong>Dear Sir/Madam,</strong></p>

        <p>Greetings from Cyrix Healthcare Pvt Ltd!!!</p>

        <p>We sincerely appreciate your continued trust in our products and services. As per your requirement, we are pleased
           to submit our proposal for <strong>{!quote.Vertical__c}</strong> for your kind consideration.</p>

        <!-- Numbered Product List -->
        <apex:variable var="pIdx" value="{!1}" />
        <apex:repeat value="{!productNamesNumbered}" var="pName">
            <p style="font-weight: bold; margin: 3px 0;">
                <apex:outputText value="{0, number, 0}">
                    <apex:param value="{!pIdx}" />
                </apex:outputText>.&lt;{!pName}&gt;
            </p>
            <apex:variable var="pIdx" value="{!pIdx + 1}" />
        </apex:repeat>

        <p>At Cyrix Healthcare, we are committed to providing high-quality medical equipment and reliable service support
           that meet your clinical and operational needs. We believe this proposal will align well with your expectations and
           add value to your facility&#8217;s healthcare delivery.</p>

        <p>Please find the detailed quotation attached for your review. Should you require any further clarification or
           technical discussion, we will be glad to assist at your convenience.</p>

        <p>Thank you for the opportunity to serve your esteemed organization.</p>

        <!-- SIGNATURE SECTION -->
        <div style="margin-top: 25px;">
            <p>With Regards,<br/>
               For Cyrix Healthcare Pvt. Ltd</p>

            <apex:image url="{!URLFOR($Resource.Stamp)}" style="max-height: 60px; max-width: 60px;" />

            <p style="color: #0000cc;"><strong>Authorized Signatory</strong></p>

            <p>For queries contact:<br/>
                <apex:outputPanel rendered="{!salesEngineerName != null}">
                    <span style="margin-left: 10px;">{!salesEngineerName}</span><br/>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!salesEngineerTitle != null}">
                    <span style="margin-left: 10px;">{!salesEngineerTitle}</span><br/>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!salesEngineerPhone != null}">
                    <span style="margin-left: 10px;">{!salesEngineerPhone}</span>
                </apex:outputPanel>
            </p>
        </div>

    </div>

    <!-- ====================================================================== -->
    <!-- PAGE 2: PRODUCT TABLE + STANDARD T&C                                  -->
    <!-- ====================================================================== -->
    <div class="page-break"></div>
    <div class="content">

        <!-- QUOTE REF LINE -->
        <table style="width: 100%; margin-bottom: 5px; font-size: 9pt; color: #cc0000; font-weight: bold;">
            <tr>
                <td style="text-align: left; width: 70%;">
                    <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
                </td>
                <td style="text-align: right; width: 30%;">
                    <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
                </td>
            </tr>
        </table>

        <!-- QUOTATION TITLE -->
        <div style="text-align: center; font-size: 9pt; font-weight: bold; margin: 5px 0 8px 0; text-decoration: underline;">
            QUOTATION FOR CYRIX {!productNamesList}<apex:outputPanel rendered="{!quote.Vertical__c != null}"> &amp; {!quote.Vertical__c}</apex:outputPanel>
        </div>

        <!-- PRICING TABLE -->
        <table style="width: 100%; border-collapse: collapse; font-size: 8pt;">
            <thead>
                <tr>
                    <th style="width: 30px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>SLN<br/>o</strong></th>
                    <th style="width: 60px; border: 1px solid #000; padding: 4px;"><strong>ITEM<br/>CODE</strong></th>
                    <th style="border: 1px solid #000; padding: 4px;"><strong>Description of Goods</strong></th>
                    <th style="width: 40px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Unit</strong></th>
                    <th style="width: 50px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Unit<br/>Price</strong></th>
                    <th style="width: 30px; border: 1px solid #000; padding: 4px; text-align: center;"><strong>Qty</strong></th>
                    <th style="width: 55px; border: 1px solid #000; padding: 4px; text-align: right;"><strong>Price</strong></th>
                </tr>
            </thead>
            <tbody>
                <apex:variable var="rowNum" value="{!1}" />
                <apex:repeat value="{!lineItems}" var="item">
                    <tr>
                        <td style="border: 1px solid #000; padding: 4px; text-align: center;">
                            <apex:outputText value="{0, number, 0}"><apex:param value="{!rowNum}" /></apex:outputText>
                        </td>
                        <td style="border: 1px solid #000; padding: 4px;">
                            <apex:outputText value="{!IF(item.Product2.Item_Code__c != null, item.Product2.Item_Code__c, item.Product2.ProductCode)}" />
                        </td>
                        <td style="border: 1px solid #000; padding: 4px;">
                            <strong>{!item.Product2.Name}</strong>
                            <apex:outputPanel rendered="{!item.Product_Line_Description__c != null}">
                                <br/><br/>({!item.Product_Line_Description__c})
                            </apex:outputPanel>
                        </td>
                        <td style="border: 1px solid #000; padding: 4px; text-align: center;">
                            <apex:outputText value="{!IF(item.Product2.QuantityUnitOfMeasure != null, item.Product2.QuantityUnitOfMeasure, 'Nos')}" />
                        </td>
                        <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                            <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!item.ListPrice}" /></apex:outputText>
                        </td>
                        <td style="border: 1px solid #000; padding: 4px; text-align: center;">
                            <apex:outputText value="{0, number, ###,##0}"><apex:param value="{!item.Quantity}" /></apex:outputText>
                        </td>
                        <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                            <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!item.TotalPrice}" /></apex:outputText>
                        </td>
                    </tr>
                    <apex:variable var="rowNum" value="{!rowNum + 1}" />
                </apex:repeat>
                <!-- Empty row -->
                <tr>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px;">&nbsp;</td>
                </tr>
                <!-- Total -->
                <tr>
                    <td style="border: none;" colspan="5">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px; text-align: right; font-weight: bold;">Total</td>
                    <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                        <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!subtotal}" /></apex:outputText>
                    </td>
                </tr>
                <!-- GST -->
                <tr>
                    <td style="border: none;" colspan="5">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px; text-align: right;">{!gstDisplayRate}</td>
                    <td style="border: 1px solid #000; padding: 4px; text-align: right;">
                        <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!taxAmount}" /></apex:outputText>
                    </td>
                </tr>
                <!-- Grand Total -->
                <tr>
                    <td style="border: none;" colspan="5">&nbsp;</td>
                    <td style="border: 1px solid #000; padding: 4px; text-align: right; font-weight: bold;">Grand Total</td>
                    <td style="border: 1px solid #000; padding: 4px; text-align: right; font-weight: bold;">
                        <apex:outputText value="{0, number, ###,##0.00}"><apex:param value="{!grandTotal}" /></apex:outputText>
                    </td>
                </tr>
            </tbody>
        </table>

        <!-- Grand Total in Words -->
        <p style="font-weight: bold; font-size: 8pt;">&lt;{!grandTotalInWords}&gt;</p>
        <p style="font-size: 7pt; font-weight: bold; color: #cc0000;">***Note: If required</p>

        <!-- STANDARD TERMS AND CONDITIONS -->
        <div style="text-align: center; font-size: 9pt; font-weight: bold; text-decoration: underline; margin: 10px 0 8px 0;">
            STANDARD TERMS AND CONDITIONS:
        </div>

        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 3px 0;">Validity</p>
        <p style="font-size: 8pt;">This quotation is valid for <strong>{!validityDays}</strong> from the date of issue and is subject to reconfirmation thereafter.</p>

        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 3px 0;">Price</p>
        <p style="font-size: 8pt;">The quoted price includes applicable levies such as GST, import duties (if any), freight, packing, forwarding, transportation, insurance, <strong><u>{!installationScope}</u></strong> at the installation site. Any additional statutory levies imposed by Government authorities shall be borne by the purchaser.</p>

        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 3px 0;">PAYMENT TERMS &amp; CONDITIONS:</p>
        <p style="font-size: 8pt;">
            <apex:outputPanel rendered="{!paymentTerms.size > 0}">
                <apex:repeat value="{!paymentTerms}" var="pt">
                    <strong>{!pt.Percentage__c}%</strong> {!pt.Payment_Term__c}<br/>
                </apex:repeat>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!paymentTerms.size == 0}">
                <strong>{!advancePercent}</strong> Advance payment with Purchase Order<br/>
                <strong>{!shippingPercent}</strong> payment on confirmation of shipping<br/>
                <strong>{!deliveryPercent}</strong> payment on delivery to site<br/>
                <strong>{!installationPercent}</strong> payment after installation and handover
            </apex:outputPanel>
        </p>

        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 3px 0;">DELIVERY</p>
        <p style="font-size: 8pt;">Delivery will be scheduled within <strong>{!deliveryWeeks}</strong> from receipt of confirmed Purchase Order along with advance payment.</p>

        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 3px 0;">Installation &amp; Approvals</p>
        <p style="font-size: 8pt;">Installation will be carried out at the approved site without additional charges, subject to site readiness confirmation from the customer. All civil, electrical, air conditioning, earthing, and related pre-installation requirements are the responsibility of the purchaser. Statutory approvals such as PC-PNDT and AERB (where applicable) must be obtained by the customer prior to installation.</p>

    </div>

    <!-- ====================================================================== -->
    <!-- PAGE 3: WARRANTY, BANK, ACCEPTANCE, CANCELLATION, SIGNATORY           -->
    <!-- ====================================================================== -->
    <div class="page-break"></div>
    <div class="content">

        <!-- QUOTE REF LINE -->
        <table style="width: 100%; margin-bottom: 5px; font-size: 9pt; color: #cc0000; font-weight: bold;">
            <tr>
                <td style="text-align: left; width: 70%;">
                    <span style="color: #000000;">C-KL/</span> {!quote.Vertical__c}<span style="color: #000000;">/{!IF(quote.Quote_Id__c != null, quote.Quote_Id__c, quote.QuoteNumber)}/2026-27-</span>&lt;if Revised&#8220;RV1&#8221;&gt;
                </td>
                <td style="text-align: right; width: 30%;">
                    <span style="color: #000000;">DATE:</span> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
                </td>
            </tr>
        </table>

        <!-- WARRANTY -->
        <p style="font-size: 10pt; font-weight: bold; text-decoration: underline; margin: 5px 0 5px 0;">Warranty</p>
        <p style="font-size: 9pt; margin-left: 10px;">
            12-month standard warranty <apex:outputPanel rendered="{!warrantyExtra != ''}"><strong><u>{!warrantyExtra}</u></strong></apex:outputPanel> from the date of installation covers manufacturing defects only.
            Repair or replacement of defective components during this period will be at the Company&#8217;s discretion.
            Warranty excludes damages arising from power fluctuations, environmental conditions, mishandling, natural
            calamities, pest-related issues, or third-party interference.
        </p>

        <!-- SITE RESPONSIBILITIES -->
        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 5px 15px;">Site Responsibilities</p>
        <p style="font-size: 9pt; margin-left: 15px;">
            The customer shall maintain recommended environmental and electrical conditions. Any damage caused due to
            non-compliance will not be covered under warranty
        </p>

        <!-- BANK DETAILS -->
        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 5px 15px;">BANK DETAILS:</p>
        <p style="font-size: 9pt; margin-left: 15px;">
            A/C Number: {!bankAccountNumber}<br/>
            Bank Name: {!bankName}<br/>
            Branch Code: {!bankBranch}<br/>
            IFSC: {!bankIfsc}
        </p>

        <!-- ACCEPTANCE OF QUOTATION -->
        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 5px 15px;">ACCEPTANCE OF QUOTATION:</p>
        <p style="font-size: 9pt; margin-left: 15px;">
            The quotation shall be considered accepted upon issuance of a formal Purchase Order or written confirmation by the
            CLIENT. Acceptance of the quotation shall constitute agreement to all terms and conditions mentioned herein.
        </p>

        <!-- CANCELLATION/REFUND NORMS -->
        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 5px 15px;">CANCELLATION/REFUND NORMS:</p>
        <p style="font-size: 9pt; margin-left: 15px;">
            Cancellation after issuance of Purchase Order will attract a <strong>10% charge</strong> on the total order value.
            Orders cannot be cancelled once the equipment is shipped.
        </p>

        <!-- FORCE MAJEURE -->
        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 5px 15px;">FORCE MAJEURE:</p>
        <p style="font-size: 9pt; margin-left: 15px;">
            The Company shall not be liable for delays or non-performance due to circumstances beyond reasonable control.
            Delivery timelines will be extended accordingly.
        </p>

        <!-- JURISDICTION -->
        <p style="font-size: 9pt; font-weight: bold; margin: 10px 0 5px 15px;">JURISDICTION:</p>
        <p style="font-size: 9pt; margin-left: 15px;">
            All disputes shall be subject to the jurisdiction of the Company&#8217;s registered office location.
        </p>

        <!-- CLOSING -->
        <p style="font-size: 9pt; margin-top: 15px;">
            Thanking you and always assuring you of our best services.
        </p>

        <p style="font-size: 10pt; font-weight: bold; margin-top: 10px;">
            For CYRIX HEALTHCARE PVT.LTD
        </p>

        <!-- STAMP/SEAL -->
        <apex:image url="{!URLFOR($Resource.Stamp)}" style="max-height: 60px; max-width: 60px;" />

        <!-- AUTHORIZED SIGNATORY -->
        <p style="font-size: 9pt; font-weight: bold; color: #0000cc;">
            Authorized Signatory
        </p>

    </div>

</body>
</html>
</apex:page>

<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>allInternalUsers</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>OrderNumber</field>
        <field>Owner</field>
        <field>TotalAmount</field>
        <field>Price_Status__c</field>
        <field>Approval_Status__c</field>
        <field>EffectiveDate</field>
        <field>Branch__c</field>
        <field>L1_Approver__c</field>
        <field>L2_Approver__c</field>
        <field>L3_Approver__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>L1_Approver__c</name>
                <type>userHierarchyField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <description>Step 1 - L1 Approver (typically ASM). Routed to the user tagged in Order.L1_Approver__c.</description>
        <label>L1 Approver</label>
        <name>L1_Approver</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>L2_Approver__c</name>
                <type>userHierarchyField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <description>Step 2 - L2 Approver (typically TSM). Routed to the user tagged in Order.L2_Approver__c.</description>
        <label>L2 Approver</label>
        <name>L2_Approver</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>L3_Approver__c</name>
                <type>userHierarchyField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <description>Step 3 - L3 Approver (typically Order Acceptance / Finance). Routed to the user tagged in Order.L3_Approver__c.</description>
        <label>L3 Approver</label>
        <name>L3_Approver</name>
    </approvalStep>
    <description>Price-based approval for Sales Orders. Mirrors the Quote Approval process with three sequential steps: Initial Price Approver, Warehouse/ERP User, and Order Acceptance Approver (final).</description>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Order.Price_Status__c</field>
            <operation>equals</operation>
            <value>Approval Required</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Order_Activated</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Order_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Order_Approved_Date_Time</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Order_Price_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Order_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Order Approval</label>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>

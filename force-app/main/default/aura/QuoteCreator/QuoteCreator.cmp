<aura:component controller="QuoteCreatorController"
    implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes"
    access="global">

    <!-- Attributes -->
    <aura:attribute name="recordId" type="String" access="global" />
    <aura:attribute name="oppDetails" type="Object" default="{}" />
    <aura:attribute name="existingQuotes" type="List" default="[]" />
    <aura:attribute name="selectedQuoteId" type="String" default="" />
    <aura:attribute name="quoteDetail" type="Object" />

    <!-- Create Quote Form -->
    <aura:attribute name="showCreateForm" type="Boolean" default="false" />
    <aura:attribute name="quoteName" type="String" default="" />
    <aura:attribute name="quoteDate" type="Date" />
    <aura:attribute name="validTill" type="Date" />
    <aura:attribute name="billingAddress" type="String" default="" />
    <aura:attribute name="shippingAddress" type="String" default="" />
    <aura:attribute name="shippingMode" type="String" default="" />
    <aura:attribute name="vertical" type="String" default="" />

    <!-- Product Search -->
    <aura:attribute name="showProductSearch" type="Boolean" default="false" />
    <aura:attribute name="searchTerm" type="String" default="" />
    <aura:attribute name="searchResults" type="List" default="[]" />
    <aura:attribute name="selectedProducts" type="List" default="[]" />

    <!-- Loading -->
    <aura:attribute name="isLoading" type="Boolean" default="false" />

    <!-- Init Handler -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <aura:html tag="style">
        .quoteCreatorModal .slds-modal__container {
            max-width: 85rem !important;
            width: 90% !important;
        }
    </aura:html>

    <lightning:card title="Quotes" iconName="standard:quotes">

        <!-- Loading Spinner -->
        <aura:if isTrue="{!v.isLoading}">
            <lightning:spinner alternativeText="Loading" size="medium" />
        </aura:if>

        <!-- Header Actions -->
        <aura:set attribute="actions">
            <lightning:button label="New Quote" iconName="utility:add" onclick="{!c.openCreateForm}" variant="brand" />
        </aura:set>

        <!-- Existing Quotes List -->
        <aura:if isTrue="{!and(v.existingQuotes.length > 0, !v.showCreateForm, !v.selectedQuoteId)}">
            <div class="slds-p-around_medium">
                <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_striped">
                    <thead>
                        <tr class="slds-line-height_reset">
                            <th scope="col"><div class="slds-truncate">Quote #</div></th>
                            <th scope="col"><div class="slds-truncate">Name</div></th>
                            <th scope="col"><div class="slds-truncate">Date</div></th>
                            <th scope="col"><div class="slds-truncate">Valid Till</div></th>
                            <th scope="col"><div class="slds-truncate">Status</div></th>
                            <th scope="col"><div class="slds-truncate">Price Status</div></th>
                            <th scope="col"><div class="slds-truncate">Items</div></th>
                            <th scope="col"><div class="slds-truncate">Grand Total</div></th>
                            <th scope="col"><div class="slds-truncate">Actions</div></th>
                        </tr>
                    </thead>
                    <tbody>
                        <aura:iteration items="{!v.existingQuotes}" var="q">
                            <tr>
                                <td><div class="slds-truncate">{!q.quoteAutoId}</div></td>
                                <td><div class="slds-truncate">{!q.quoteName}</div></td>
                                <td><div class="slds-truncate">
                                    <lightning:formattedDateTime value="{!q.quoteDate}" year="numeric" month="short" day="2-digit" />
                                </div></td>
                                <td><div class="slds-truncate">
                                    <lightning:formattedDateTime value="{!q.validTill}" year="numeric" month="short" day="2-digit" />
                                </div></td>
                                <td><div class="slds-truncate">
                                    <lightning:badge label="{!q.status}" />
                                </div></td>
                                <td><div class="slds-truncate">
                                    <aura:if isTrue="{!q.priceStatus == 'Approved'}">
                                        <span class="slds-badge slds-theme_success">{!q.priceStatus}</span>
                                    </aura:if>
                                    <aura:if isTrue="{!q.priceStatus == 'Rejected'}">
                                        <span class="slds-badge slds-theme_error">{!q.priceStatus}</span>
                                    </aura:if>
                                    <aura:if isTrue="{!q.priceStatus == 'Approval Required'}">
                                        <span class="slds-badge slds-theme_warning">{!q.priceStatus}</span>
                                    </aura:if>
                                    <aura:if isTrue="{!q.priceStatus == 'Draft'}">
                                        <lightning:badge label="{!q.priceStatus}" />
                                    </aura:if>
                                </div></td>
                                <td><div class="slds-truncate">{!q.lineItemCount}</div></td>
                                <td><div class="slds-truncate">
                                    <lightning:formattedNumber value="{!q.grandTotal}" style="currency" currencyCode="INR" />
                                </div></td>
                                <td>
                                    <lightning:buttonIcon iconName="utility:preview" alternativeText="View" title="View Details"
                                        value="{!q.quoteId}" onclick="{!c.viewQuoteDetails}" variant="border-filled" size="small" />
                                </td>
                            </tr>
                        </aura:iteration>
                    </tbody>
                </table>
            </div>
        </aura:if>

        <!-- No Quotes Message -->
        <aura:if isTrue="{!and(v.existingQuotes.length == 0, !v.showCreateForm, !v.selectedQuoteId, !v.isLoading)}">
            <div class="slds-p-around_large slds-text-align_center">
                <div class="slds-illustration slds-illustration_small">
                    <lightning:icon iconName="standard:quotes" size="large" class="slds-m-bottom_medium" />
                    <div class="slds-text-longform">
                        <h3 class="slds-text-heading_medium">No Quotes Found</h3>
                        <p class="slds-text-body_regular slds-m-top_x-small">Create a new quote to get started.</p>
                    </div>
                </div>
            </div>
        </aura:if>

        <!-- Quote Detail View -->
        <aura:if isTrue="{!and(v.selectedQuoteId != '', !v.showCreateForm)}">
            <div class="slds-p-around_medium">
                <div class="slds-m-bottom_medium">
                    <lightning:button label="Back to Quotes" iconName="utility:back" onclick="{!c.backToList}" variant="neutral" />
                    <lightning:button label="Add Products" iconName="utility:add" onclick="{!c.openProductSearchForExisting}" variant="brand" class="slds-m-left_x-small" />
                </div>

                <aura:if isTrue="{!v.quoteDetail != null}">
                    <!-- Quote Header Info -->
                    <div class="slds-card slds-m-bottom_medium">
                        <div class="slds-card__header slds-grid">
                            <div class="slds-media slds-media_center slds-has-flexi-truncate">
                                <div class="slds-media__figure">
                                    <lightning:icon iconName="standard:quotes" size="small" />
                                </div>
                                <div class="slds-media__body">
                                    <h2 class="slds-card__header-title">
                                        <span class="slds-text-heading_small">Quote Details</span>
                                    </h2>
                                </div>
                            </div>
                        </div>
                        <div class="slds-card__body slds-p-around_medium">
                            <div class="slds-grid slds-wrap slds-gutters">
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Quote Number</p>
                                    <p class="slds-text-body_regular">{!v.quoteDetail.quote.QuoteNumber}</p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Quote ID</p>
                                    <p class="slds-text-body_regular">{!v.quoteDetail.quote.Quote_Id__c}</p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Status</p>
                                    <p class="slds-text-body_regular">{!v.quoteDetail.quote.Status}</p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Price Status</p>
                                    <p class="slds-text-body_regular">{!v.quoteDetail.quote.Price_Status__c}</p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Quote Date</p>
                                    <p class="slds-text-body_regular">
                                        <lightning:formattedDateTime value="{!v.quoteDetail.quote.Quote_Date__c}" year="numeric" month="short" day="2-digit" />
                                    </p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Valid Till</p>
                                    <p class="slds-text-body_regular">
                                        <lightning:formattedDateTime value="{!v.quoteDetail.quote.Valid_Till__c}" year="numeric" month="short" day="2-digit" />
                                    </p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Vertical</p>
                                    <p class="slds-text-body_regular">{!v.quoteDetail.quote.Vertical__c}</p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Shipping Mode</p>
                                    <p class="slds-text-body_regular">{!v.quoteDetail.quote.Shipping_Mode__c}</p>
                                </div>
                                <div class="slds-col slds-size_1-of-3 slds-m-bottom_small">
                                    <p class="slds-text-title">Grand Total</p>
                                    <p class="slds-text-body_regular">
                                        <lightning:formattedNumber value="{!v.quoteDetail.quote.GrandTotal}" style="currency" currencyCode="INR" />
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Line Items Table -->
                    <div class="slds-card">
                        <div class="slds-card__header slds-grid">
                            <div class="slds-media slds-media_center slds-has-flexi-truncate">
                                <div class="slds-media__figure">
                                    <lightning:icon iconName="standard:product" size="small" />
                                </div>
                                <div class="slds-media__body">
                                    <h2 class="slds-card__header-title">
                                        <span class="slds-text-heading_small">Line Items ({!v.quoteDetail.lineItems.length})</span>
                                    </h2>
                                </div>
                            </div>
                        </div>
                        <div class="slds-card__body">
                            <aura:if isTrue="{!v.quoteDetail.lineItems.length > 0}">
                                <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_striped">
                                    <thead>
                                        <tr class="slds-line-height_reset">
                                            <th scope="col"><div class="slds-truncate">#</div></th>
                                            <th scope="col"><div class="slds-truncate">Product</div></th>
                                            <th scope="col"><div class="slds-truncate">Code</div></th>
                                            <th scope="col"><div class="slds-truncate">Qty</div></th>
                                            <th scope="col"><div class="slds-truncate">Unit Price</div></th>
                                            <th scope="col"><div class="slds-truncate">Discount %</div></th>
                                            <th scope="col"><div class="slds-truncate">Tax Type</div></th>
                                            <th scope="col"><div class="slds-truncate">Total</div></th>
                                            <th scope="col"><div class="slds-truncate">Status</div></th>
                                            <th scope="col"><div class="slds-truncate">Actions</div></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration items="{!v.quoteDetail.lineItems}" var="li" indexVar="idx">
                                            <tr>
                                                <td><div class="slds-truncate">{!idx + 1}</div></td>
                                                <td><div class="slds-truncate" title="{!li.productName}">{!li.productName}</div></td>
                                                <td><div class="slds-truncate">{!li.productCode}</div></td>
                                                <td><div class="slds-truncate">{!li.quantity}</div></td>
                                                <td><div class="slds-truncate">
                                                    <lightning:formattedNumber value="{!li.unitPrice}" style="currency" currencyCode="INR" />
                                                </div></td>
                                                <td><div class="slds-truncate">{!li.discount}%</div></td>
                                                <td><div class="slds-truncate">{!li.taxType}</div></td>
                                                <td><div class="slds-truncate">
                                                    <lightning:formattedNumber value="{!li.totalPrice}" style="currency" currencyCode="INR" />
                                                </div></td>
                                                <td><div class="slds-truncate">
                                                    <lightning:badge label="{!li.priceStatus}" />
                                                </div></td>
                                                <td>
                                                    <lightning:buttonIcon iconName="utility:delete" alternativeText="Delete"
                                                        value="{!li.lineItemId}" onclick="{!c.deleteLineItem}" variant="bare"
                                                        iconClass="slds-icon-text-error" size="small" />
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                            </aura:if>
                            <aura:if isTrue="{!v.quoteDetail.lineItems.length == 0}">
                                <div class="slds-p-around_medium slds-text-align_center slds-text-color_weak">
                                    No line items found. Click "Add Products" to add items.
                                </div>
                            </aura:if>
                        </div>
                    </div>
                </aura:if>
            </div>
        </aura:if>

        <!-- Create Quote Form (Modal) -->
        <aura:if isTrue="{!v.showCreateForm}">
            <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open quoteCreatorModal">
                <div class="slds-modal__container">
                    <lightning:buttonIcon iconName="utility:close" onclick="{!c.closeCreateForm}" alternativeText="Close"
                        variant="" class="slds-modal__close" />
                    <header class="slds-modal__header">
                        <h2 class="slds-modal__title slds-hyphenate">Create New Quote</h2>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" style="overflow-y: auto; max-height: 70vh;">
                        <!-- Quote Details Section -->
                        <div class="slds-card slds-m-bottom_medium">
                            <div class="slds-card__header">
                                <h3 class="slds-text-heading_small">
                                    <lightning:icon iconName="utility:description" size="x-small" class="slds-m-right_x-small" />
                                    Quote Information
                                </h3>
                            </div>
                            <div class="slds-card__body slds-p-around_medium">
                                <div class="slds-grid slds-wrap slds-gutters">
                                    <div class="slds-col slds-size_1-of-2 slds-m-bottom_small">
                                        <lightning:input label="Quote Name" value="{!v.quoteName}" required="true" aura:id="quoteName" />
                                    </div>
                                    <div class="slds-col slds-size_1-of-2 slds-m-bottom_small">
                                        <lightning:input type="date" label="Quote Date" value="{!v.quoteDate}" required="true" aura:id="quoteDate" />
                                    </div>
                                    <div class="slds-col slds-size_1-of-2 slds-m-bottom_small">
                                        <lightning:input type="date" label="Valid Till" value="{!v.validTill}" aura:id="validTill" />
                                    </div>
                                    <div class="slds-col slds-size_1-of-2 slds-m-bottom_small">
                                        <lightning:select label="Shipping Mode" value="{!v.shippingMode}" aura:id="shippingMode">
                                            <option value="">--None--</option>
                                            <option value="By Road">By Road</option>
                                            <option value="By Air">By Air</option>
                                            <option value="By Sea">By Sea</option>
                                            <option value="By Rail">By Rail</option>
                                            <option value="Courier">Courier</option>
                                        </lightning:select>
                                    </div>
                                    <div class="slds-col slds-size_1-of-2 slds-m-bottom_small">
                                        <lightning:select label="Vertical" value="{!v.vertical}" aura:id="vertical">
                                            <option value="">--None--</option>
                                            <option value="Medical Equipment">Medical Equipment</option>
                                            <option value="Surgical Instruments">Surgical Instruments</option>
                                            <option value="Lab Equipment">Lab Equipment</option>
                                            <option value="Consumables">Consumables</option>
                                            <option value="Services">Services</option>
                                        </lightning:select>
                                    </div>
                                    <div class="slds-col slds-size_1-of-2 slds-m-bottom_small">
                                        <lightning:input label="Opportunity" value="{!v.oppDetails.opportunityName}" readonly="true" />
                                    </div>
                                    <div class="slds-col slds-size_1-of-1 slds-m-bottom_small">
                                        <lightning:textarea label="Billing Address" value="{!v.billingAddress}" maxlength="32768" />
                                    </div>
                                    <div class="slds-col slds-size_1-of-1 slds-m-bottom_small">
                                        <lightning:textarea label="Shipping Address" value="{!v.shippingAddress}" maxlength="32768" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Product Search Section -->
                        <div class="slds-card slds-m-bottom_medium">
                            <div class="slds-card__header">
                                <h3 class="slds-text-heading_small">
                                    <lightning:icon iconName="utility:search" size="x-small" class="slds-m-right_x-small" />
                                    Add Products
                                </h3>
                            </div>
                            <div class="slds-card__body slds-p-around_medium">
                                <div class="slds-grid slds-gutters slds-m-bottom_small">
                                    <div class="slds-col slds-size_3-of-4">
                                        <lightning:input label="Search Products" placeholder="Search by name, code, make, or model..."
                                            value="{!v.searchTerm}" aura:id="searchInput" onchange="{!c.handleSearchKeyChange}" />
                                    </div>
                                    <div class="slds-col slds-size_1-of-4 slds-grid slds-grid_vertical-align-end">
                                        <lightning:button label="Search" iconName="utility:search" onclick="{!c.searchProducts}" variant="neutral" />
                                    </div>
                                </div>

                                <!-- Search Results -->
                                <aura:if isTrue="{!v.searchResults.length > 0}">
                                    <div class="slds-scrollable_y" style="max-height: 250px;">
                                        <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_fixed-layout">
                                            <thead>
                                                <tr class="slds-line-height_reset">
                                                    <th scope="col" style="width:40px;"></th>
                                                    <th scope="col"><div class="slds-truncate">Product</div></th>
                                                    <th scope="col"><div class="slds-truncate">Code</div></th>
                                                    <th scope="col"><div class="slds-truncate">Make</div></th>
                                                    <th scope="col"><div class="slds-truncate">Unit Price</div></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <aura:iteration items="{!v.searchResults}" var="p">
                                                    <tr class="productRow" data-product-id="{!p.productId}" onclick="{!c.addProductToCart}">
                                                        <td>
                                                            <lightning:icon iconName="utility:add" size="xx-small" alternativeText="Add" />
                                                        </td>
                                                        <td><div class="slds-truncate" title="{!p.productName}">{!p.productName}</div></td>
                                                        <td><div class="slds-truncate">{!p.productCode}</div></td>
                                                        <td><div class="slds-truncate">{!p.make}</div></td>
                                                        <td><div class="slds-truncate">
                                                            <lightning:formattedNumber value="{!p.unitPrice}" style="currency" currencyCode="INR" />
                                                        </div></td>
                                                    </tr>
                                                </aura:iteration>
                                            </tbody>
                                        </table>
                                    </div>
                                </aura:if>
                            </div>
                        </div>

                        <!-- Selected Products / Line Items -->
                        <aura:if isTrue="{!v.selectedProducts.length > 0}">
                            <div class="slds-card slds-m-bottom_medium">
                                <div class="slds-card__header">
                                    <h3 class="slds-text-heading_small">
                                        <lightning:icon iconName="utility:cart" size="x-small" class="slds-m-right_x-small" />
                                        Selected Products ({!v.selectedProducts.length})
                                    </h3>
                                </div>
                                <div class="slds-card__body slds-p-around_medium">
                                    <div class="slds-scrollable_y" style="max-height: 300px;">
                                        <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                            <thead>
                                                <tr class="slds-line-height_reset">
                                                    <th scope="col"><div class="slds-truncate">Product</div></th>
                                                    <th scope="col"><div class="slds-truncate">Qty</div></th>
                                                    <th scope="col"><div class="slds-truncate">Unit Price</div></th>
                                                    <th scope="col"><div class="slds-truncate">Discount %</div></th>
                                                    <th scope="col"><div class="slds-truncate">Tax Type</div></th>
                                                    <th scope="col"><div class="slds-truncate">Description</div></th>
                                                    <th scope="col" style="width:50px;"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <aura:iteration items="{!v.selectedProducts}" var="sp" indexVar="spIdx">
                                                    <tr>
                                                        <td><div class="slds-truncate" title="{!sp.productName}">{!sp.productName}</div></td>
                                                        <td>
                                                            <lightning:input type="number" value="{!sp.quantity}" min="1" step="1"
                                                                variant="label-hidden" class="qty-input" onchange="{!c.updateLineItem}" />
                                                        </td>
                                                        <td>
                                                            <lightning:input type="number" value="{!sp.unitPrice}" min="0" step="0.01"
                                                                variant="label-hidden" class="price-input" formatter="currency"
                                                                onchange="{!c.updateLineItem}" />
                                                        </td>
                                                        <td>
                                                            <lightning:input type="number" value="{!sp.discount}" min="0" max="100" step="0.01"
                                                                variant="label-hidden" class="discount-input" onchange="{!c.updateLineItem}" />
                                                        </td>
                                                        <td>
                                                            <lightning:select value="{!sp.taxType}" variant="label-hidden">
                                                                <option value="GST">GST</option>
                                                                <option value="IGST">IGST</option>
                                                                <option value="Exempt">Exempt</option>
                                                            </lightning:select>
                                                        </td>
                                                        <td>
                                                            <lightning:input value="{!sp.lineDescription}" variant="label-hidden"
                                                                placeholder="Line description" />
                                                        </td>
                                                        <td>
                                                            <lightning:buttonIcon iconName="utility:delete" alternativeText="Remove"
                                                                value="{!spIdx}" onclick="{!c.removeFromCart}" variant="bare"
                                                                iconClass="slds-icon-text-error" size="small" />
                                                        </td>
                                                    </tr>
                                                </aura:iteration>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </aura:if>
                    </div>
                    <footer class="slds-modal__footer">
                        <lightning:button label="Cancel" onclick="{!c.closeCreateForm}" />
                        <lightning:button label="Save Quote" variant="brand" onclick="{!c.saveQuote}" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </aura:if>

        <!-- Add Products Modal (for existing quote) -->
        <aura:if isTrue="{!v.showProductSearch}">
            <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open quoteCreatorModal">
                <div class="slds-modal__container">
                    <lightning:buttonIcon iconName="utility:close" onclick="{!c.closeProductSearch}" alternativeText="Close"
                        variant="" class="slds-modal__close" />
                    <header class="slds-modal__header">
                        <h2 class="slds-modal__title slds-hyphenate">Add Products to Quote</h2>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" style="overflow-y: auto; max-height: 70vh;">
                        <!-- Product Search -->
                        <div class="slds-grid slds-gutters slds-m-bottom_small">
                            <div class="slds-col slds-size_3-of-4">
                                <lightning:input label="Search Products" placeholder="Search by name, code, make, or model..."
                                    value="{!v.searchTerm}" onchange="{!c.handleSearchKeyChange}" />
                            </div>
                            <div class="slds-col slds-size_1-of-4 slds-grid slds-grid_vertical-align-end">
                                <lightning:button label="Search" iconName="utility:search" onclick="{!c.searchProducts}" variant="neutral" />
                            </div>
                        </div>

                        <!-- Search Results -->
                        <aura:if isTrue="{!v.searchResults.length > 0}">
                            <div class="slds-scrollable_y slds-m-bottom_medium" style="max-height: 250px;">
                                <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_fixed-layout">
                                    <thead>
                                        <tr class="slds-line-height_reset">
                                            <th scope="col" style="width:40px;"></th>
                                            <th scope="col"><div class="slds-truncate">Product</div></th>
                                            <th scope="col"><div class="slds-truncate">Code</div></th>
                                            <th scope="col"><div class="slds-truncate">Make</div></th>
                                            <th scope="col"><div class="slds-truncate">Unit Price</div></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration items="{!v.searchResults}" var="p">
                                            <tr class="productRow" onclick="{!c.addProductToCart}">
                                                <td><lightning:icon iconName="utility:add" size="xx-small" alternativeText="Add" /></td>
                                                <td><div class="slds-truncate">{!p.productName}</div></td>
                                                <td><div class="slds-truncate">{!p.productCode}</div></td>
                                                <td><div class="slds-truncate">{!p.make}</div></td>
                                                <td><div class="slds-truncate">
                                                    <lightning:formattedNumber value="{!p.unitPrice}" style="currency" currencyCode="INR" />
                                                </div></td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                            </div>
                        </aura:if>

                        <!-- Selected Products -->
                        <aura:if isTrue="{!v.selectedProducts.length > 0}">
                            <h3 class="slds-text-heading_small slds-m-bottom_x-small">
                                Selected Products ({!v.selectedProducts.length})
                            </h3>
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th scope="col"><div class="slds-truncate">Product</div></th>
                                        <th scope="col"><div class="slds-truncate">Qty</div></th>
                                        <th scope="col"><div class="slds-truncate">Unit Price</div></th>
                                        <th scope="col"><div class="slds-truncate">Discount %</div></th>
                                        <th scope="col"><div class="slds-truncate">Tax Type</div></th>
                                        <th scope="col" style="width:50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!v.selectedProducts}" var="sp" indexVar="spIdx">
                                        <tr>
                                            <td><div class="slds-truncate">{!sp.productName}</div></td>
                                            <td><lightning:input type="number" value="{!sp.quantity}" min="1" step="1" variant="label-hidden" /></td>
                                            <td><lightning:input type="number" value="{!sp.unitPrice}" min="0" step="0.01" variant="label-hidden" formatter="currency" /></td>
                                            <td><lightning:input type="number" value="{!sp.discount}" min="0" max="100" step="0.01" variant="label-hidden" /></td>
                                            <td>
                                                <lightning:select value="{!sp.taxType}" variant="label-hidden">
                                                    <option value="GST">GST</option>
                                                    <option value="IGST">IGST</option>
                                                    <option value="Exempt">Exempt</option>
                                                </lightning:select>
                                            </td>
                                            <td>
                                                <lightning:buttonIcon iconName="utility:delete" alternativeText="Remove"
                                                    value="{!spIdx}" onclick="{!c.removeFromCart}" variant="bare"
                                                    iconClass="slds-icon-text-error" size="small" />
                                            </td>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                        </aura:if>
                    </div>
                    <footer class="slds-modal__footer">
                        <lightning:button label="Cancel" onclick="{!c.closeProductSearch}" />
                        <lightning:button label="Add to Quote" variant="brand" onclick="{!c.addItemsToExistingQuote}" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </aura:if>

    </lightning:card>

</aura:component>